/*
  Global Portfolio Styles
  - Off-white background + lavender palette
  - Premium soft cards
  - Timeline, carousels, and 3D project flip
*/

:root {
  --bg: #f8f6f2;
  --text: #2d2d2d;
  --text-body: #555;
  --accent: #b39ddb;
  --accent-deep: #9c7bb5;

  --card-radius: 20px;
  --card-shadow: 0 8px 32px rgba(179, 157, 219, 0.2);
  --card-shadow-hover: 0 14px 40px rgba(156, 123, 181, 0.3);

  --navbar-h: 74px;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: calc(var(--navbar-h) + 12px);
}

body {
  margin: 0;
  font-family: 'Inter', system-ui, sans-serif;
  background: var(--bg);
  color: var(--text);
}

a {
  color: inherit;
  text-decoration: none;
}

.container {
  width: min(1120px, 92vw);
  margin: 0 auto;
}

/* =====================
   Navbar
===================== */
.navbar {
  position: sticky;
  top: 0;
  z-index: 1000;
  height: var(--navbar-h);
  background: rgba(248, 246, 242, 0.95);
  border-bottom: 1px solid rgba(156, 123, 181, 0.2);
  -webkit-backdrop-filter: blur(10px);
  backdrop-filter: blur(10px);
}

.navbar-inner {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.logo-link {
  display: inline-flex;
  align-items: center;
}

.logo-svg {
  width: 58px;
  height: 58px;
  transition: transform 220ms ease;
}

.logo-link:hover .logo-svg {
  transform: scale(1.05);
}

.logo-circle-fill {
  fill: #d1c4e9;
}

.logo-monogram {
  font-family: 'Great Vibes', cursive;
  font-size: 46px;
  fill: #5f4a72;
}

.nav-links {
  margin: 0;
  padding: 0;
  color: #5f4a72;
  display: flex;
  gap: 16px;
  overflow-x: auto;
}

.nav-links a {
  color: var(--text);
  font-weight: 500;
  position: relative;
  white-space: nowrap;
  transition: color 180ms ease;
}

.nav-links a::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -6px;
  width: 0;
  height: 2px;
  border-radius: 999px;
  background: var(--accent-deep);
  transition: width 180ms ease;
}

.nav-links a:hover {
  color: var(--accent-deep);
}

.nav-links a:hover::after {
  width: 100%;
}

/* =====================
   Shared Section + Text
===================== */
.content-section {
  padding: 84px 0;
}

.section-heading {
  margin-bottom: 26px;
}

.section-label {
  margin: 0 0 10px;
  font-size: 0.78rem;
  font-variant: small-caps;
  letter-spacing: 0.15em;
  color: var(--accent-deep);
  font-weight: 700;
  text-transform: uppercase;
}

.section-heading h2 {
  margin: 0;
  color: var(--text);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
}

.card-title {
  margin: 0;
  color: var(--text);
  font-size: 1.2rem;
  font-weight: 800;
}

.card-body-text {
  color: var(--text-body);
  font-size: 1rem;
  line-height: 1.7;
}

.section-reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 560ms ease, transform 560ms ease;
}

.section-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.section-reveal-right {
  opacity: 0;
  transform: translateX(22px);
  transition: opacity 620ms ease, transform 620ms ease;
}

.section-reveal-right.visible {
  opacity: 1;
  transform: translateX(0);
}

/* Premium card system */
.premium-card,
.carousel-card,
.education-card,
.skills-group-card,
.learning-card,
.fact-card,
.contact-heading,
.flip-face {
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  border: 1px solid rgba(156, 123, 181, 0.15);
  background: #fff;
}

.carousel-card,
.education-card,
.skills-group-card,
.learning-card,
.fact-card,
.contact-heading {
  transition: transform 250ms ease, box-shadow 250ms ease;
}

.carousel-card:hover,
.education-card:hover,
.skills-group-card:hover,
.learning-card:hover,
.fact-card:hover,
.contact-heading:hover {
  transform: translateY(-6px);
  box-shadow: var(--card-shadow-hover);
}

/* =====================
   Hero
===================== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 30px 0;
}

.hero-particle-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.hero-particle {
  position: absolute;
  bottom: -24px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(179, 157, 219, 0.9) 0%, rgba(179, 157, 219, 0) 74%);
  animation-name: particleFloat;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.hero-layout {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 0.9fr;
  align-items: center;
  gap: 34px;
}

.hero-content {
  max-width: 760px;
}

.hero-kicker {
  margin: 0 0 12px;
  color: var(--accent-deep);
  font-weight: 700;
}

.hero-name {
  margin: 0;
  display: inline-flex;
  flex-wrap: wrap;
  font-size: clamp(2.6rem, 7vw, 5rem);
  line-height: 1.05;
  cursor: default;
}

.hero-letter {
  display: inline-block;
  transition: transform 640ms cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform;
}

.hero-opening {
  margin: 16px 0;
  font-size: clamp(1rem, 2.3vw, 1.3rem);
  max-width: 65ch;
  color: #5f4a72;
  display: inline-flex;
  flex-wrap: wrap;
}

.hero-wave-letter {
  display: inline-block;
  animation: waveRipple 2.2s ease-in-out infinite;
  will-change: transform;
  font-weight: 600;
}

.hero-bio {
  margin: 0;
  max-width: 72ch;
  color: var(--text-body);
  line-height: 1.7;
  cursor: pointer;
  outline: none;
}

.hero-bio-word {
  display: inline-block;
  margin-right: 0.35em;
  transition: transform 520ms ease;
  will-change: transform;
}

.hero-bio-hint {
  margin: 6px 0 0;
  color: var(--accent-deep);
  opacity: 0.85;
  font-size: 0.82rem;
}

.hero-actions {
  margin-top: 24px;
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.hero-visual {
  position: relative;
  min-height: 360px;
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(2px);
  opacity: 0.82;
  animation: orbFloat 6.2s ease-in-out infinite;
}

.orb-1 {
  width: 180px;
  height: 180px;
  top: 12%;
  left: 8%;
  background: rgba(179, 157, 219, 0.6);
}

.orb-2 {
  width: 120px;
  height: 120px;
  top: 50%;
  left: 38%;
  background: rgba(246, 198, 229, 0.58);
  animation-delay: 0.8s;
}

.orb-3 {
  width: 210px;
  height: 210px;
  top: 24%;
  right: 8%;
  background: rgba(205, 241, 233, 0.6);
  animation-delay: 1.5s;
}

.orb-4 {
  width: 95px;
  height: 95px;
  bottom: 10%;
  right: 28%;
  background: rgba(179, 157, 219, 0.44);
  animation-delay: 2.3s;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid transparent;
  border-radius: 999px;
  padding: 12px 22px;
  font-weight: 600;
  transition: transform 200ms ease, box-shadow 200ms ease, background-color 200ms ease, color 200ms ease;
}

.btn:hover {
  transform: translateY(-4px);
}

.btn-primary {
  background: var(--accent);
  color: #fff;
  box-shadow: 0 10px 24px rgba(156, 123, 181, 0.33);
}

.btn-secondary {
  background: #f1e9fb;
  color: #5b4672;
  border-color: rgba(156, 123, 181, 0.4);
}

.btn-secondary:hover {
  background: var(--accent-deep);
  color: #fff;
  box-shadow: 0 12px 30px rgba(156, 123, 181, 0.36);
}

/* =====================
   Carousel shared
===================== */
.carousel-controls {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-bottom: 14px;
}

.arrow-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 1px solid rgba(156, 123, 181, 0.35);
  background: #fff;
  color: var(--accent-deep);
  cursor: pointer;
  transition: background-color 180ms ease, color 180ms ease;
}

.arrow-btn:hover {
  background: var(--accent);
  color: #fff;
}

.carousel-track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(290px, 43%);
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding-bottom: 8px;
  cursor: grab;
}

.carousel-track.is-dragging {
  cursor: grabbing;
  -webkit-user-select: none;
  user-select: none;
}

.carousel-track::-webkit-scrollbar {
  height: 8px;
}

.carousel-track::-webkit-scrollbar-thumb {
  background: rgba(156, 123, 181, 0.35);
  border-radius: 999px;
}

.carousel-card,
.flip-scene {
  scroll-snap-align: start;
}

.card-gradient-header {
  width: 100%;
  min-height: 170px;
}

/* =====================
   Experience cards
===================== */
.experience-body {
  padding: 18px;
}

.experience-meta {
  margin-top: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.university-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  background: #f0e8fa;
  color: #5f4a72;
  padding: 6px 11px;
  font-size: 0.84rem;
  font-weight: 700;
}

.date-pill {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  background: rgba(156, 123, 181, 0.12);
  color: var(--accent-deep);
  padding: 6px 11px;
  font-size: 0.82rem;
  font-weight: 700;
}

.experience-points {
  margin: 14px 0 0;
  padding-left: 18px;
  color: var(--text-body);
}

.experience-points li {
  margin-bottom: 8px;
}

/* =====================
   Education timeline
===================== */
.education-timeline {
  position: relative;
  display: grid;
  gap: 18px;
}

.education-row {
  display: grid;
  grid-template-columns: 46px 1fr;
  align-items: stretch;
  gap: 16px;
}

.timeline-rail {
  position: relative;
}

.timeline-rail::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: -18px;
  left: 50%;
  transform: translateX(-50%);
  width: 3px;
  border-radius: 999px;
  background: var(--accent);
}

.education-row:last-child .timeline-rail::before {
  bottom: 0;
}

.timeline-dot {
  position: absolute;
  top: 28px;
  left: 50%;
  transform: translateX(-50%);
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: var(--accent-deep);
  border: 3px solid #f8f6f2;
  box-shadow: 0 0 0 2px rgba(156, 123, 181, 0.25);
}

.education-card {
  overflow: hidden;
}

.education-media {
  min-height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.education-media-icon {
  font-size: 2rem;
  background: rgba(255, 255, 255, 0.22);
  border-radius: 14px;
  padding: 10px 14px;
}

.education-content {
  padding: 18px;
}

.education-degree {
  margin: 10px 0;
  color: #4a3b58;
  font-weight: 700;
}

.education-meta {
  margin-bottom: 8px;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.location-chip {
  border-radius: 999px;
  padding: 6px 11px;
  font-size: 0.82rem;
  font-weight: 600;
  color: #5f4a72;
  background: #f0e8fa;
}

/* =====================
   Projects flip cards
===================== */
.flip-scene {
  perspective: 1200px;
  min-height: 380px;
}

.flip-inner {
  position: relative;
  width: 100%;
  min-height: 380px;
  transform-style: preserve-3d;
  transition: transform 680ms ease;
  cursor: pointer;
}

.flip-scene:hover .flip-inner {
  transform: translateY(-6px);
}

.flip-inner.is-flipped {
  transform: rotateY(180deg);
}

.flip-face {
  position: absolute;
  inset: 0;
  overflow: hidden;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

.flip-front {
  position: absolute;
}

.project-front-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.24), rgba(0, 0, 0, 0));
}

.project-front-title {
  position: absolute;
  left: 50%;
  bottom: 18px;
  transform: translateX(-50%);
  width: calc(100% - 24px);
  text-align: center;
  color: #fff;
  font-size: 1.2rem;
  font-weight: 800;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.28);
}

.flip-back {
  transform: rotateY(180deg);
  padding: 18px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12px;
  background: #fff;
}

.project-back-text {
  margin: 0;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.tech-tag {
  border-radius: 999px;
  background: #f1e9fb;
  color: #5f4a72;
  padding: 6px 10px;
  font-size: 0.84rem;
  font-weight: 600;
}

.project-link,
.project-no-link {
  font-weight: 700;
  color: var(--accent-deep);
}

/* =====================
   Skills / Learning / Fun Facts
===================== */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 14px;
}

.skills-group-card,
.learning-card,
.fact-card {
  padding: 18px;
}

.skills-group-card h3,
.fact-card h3 {
  margin: 0 0 12px;
  font-size: 1.2rem;
  color: var(--text);
}

.skills-chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.skill-chip {
  border-radius: 999px;
  background: #efe7fa;
  color: #4e3f5c;
  padding: 6px 11px;
  font-size: 0.85rem;
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.skill-chip:hover {
  transform: translateY(-1px);
  box-shadow: 0 0 0 3px rgba(179, 157, 219, 0.3);
}

.learning-grid,
.facts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 14px;
}

.learning-card {
  text-align: center;
  animation: learningPulse 2.6s ease-in-out infinite;
}

.learning-card p,
.fact-card p {
  margin: 0;
  color: var(--text-body);
  line-height: 1.7;
}

.fact-icon {
  font-size: 1.7rem;
}

/* =====================
   Contact (minimal)
===================== */
.contact-heading {
  max-width: 680px;
  margin: 0 auto;
  padding: 34px 24px;
  text-align: center;
}

.contact-line {
  margin: 14px auto 18px;
  max-width: 48ch;
}

.connect-mail-btn {
  display: inline-flex;
  border-radius: 999px;
  padding: 12px 22px;
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  transition: background-color 180ms ease, transform 180ms ease;
}

.connect-mail-btn:hover {
  background: var(--accent-deep);
  transform: translateY(-2px);
}

.connect-links {
  margin-top: 16px;
  display: flex;
  justify-content: center;
  gap: 12px;
}

.connect-links a {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #fff;
  color: var(--accent-deep);
  border: 1px solid rgba(156, 123, 181, 0.3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 180ms ease, background-color 180ms ease, color 180ms ease;
}

.connect-links a:hover {
  transform: translateY(-2px);
  background: var(--accent-deep);
  color: #fff;
}

.connect-icon {
  width: 18px;
  height: 18px;
}

/* =====================
   Footer
===================== */
.site-footer {
  border-top: 1px solid rgba(156, 123, 181, 0.2);
  padding: 18px 0 28px;
}

.footer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}

.footer-row p {
  margin: 0;
  color: #5c4a6f;
  font-weight: 600;
}

.footer-links {
  display: flex;
  gap: 10px;
}

.footer-links a {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 1px solid rgba(156, 123, 181, 0.25);
  color: #6b5290;
  transition: transform 180ms ease, background-color 180ms ease, color 180ms ease;
}

.footer-links a:hover {
  transform: translateY(-2px);
  background: var(--accent);
  color: #fff;
}

.social-icon {
  width: 18px;
  height: 18px;
}

/* =====================
   Animations
===================== */
@keyframes particleFloat {
  0% {
    transform: translateY(0) scale(0.95);
    opacity: 0;
  }
  18% {
    opacity: 0.55;
  }
  100% {
    transform: translateY(-120vh) scale(1.1);
    opacity: 0;
  }
}

@keyframes waveRipple {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-7px);
  }
}

@keyframes orbFloat {
  0%,
  100% {
    transform: translateY(0) scale(1);
    opacity: 0.75;
  }
  50% {
    transform: translateY(-14px) scale(1.04);
    opacity: 1;
  }
}

@keyframes learningPulse {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
}

/* =====================
   Responsive
===================== */
@media (max-width: 940px) {
  .carousel-track {
    grid-auto-columns: 80%;
  }
}

@media (max-width: 720px) {
  .navbar {
    height: 66px;
  }

  .logo-svg {
    width: 50px;
    height: 50px;
  }

  .nav-links {
    gap: 12px;
  }

  .content-section {
    padding: 68px 0;
  }

  .hero {
    min-height: 100vh;
    padding: 20px 0;
  }

  .hero-layout {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .hero-visual {
    min-height: 220px;
  }

  .carousel-track {
    grid-auto-columns: 90%;
  }

  .education-row {
    grid-template-columns: 34px 1fr;
    gap: 10px;
  }

  .timeline-dot {
    width: 14px;
    height: 14px;
  }
}
